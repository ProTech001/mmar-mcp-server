{"uuid":"00162ada-0c40-4622-be98-8a9743c3139b","name":"Flowchart Trial 3","geometry":null,"description":"A Flowchart modeling language with Start, End, Process, and Decision nodes connected by Flow connections.","coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"classes":[{"uuid":"a51ff3af-c210-4ddd-9fbe-787c2d7a6ad4","name":"Start","geometry":"/** @param {GraphicContext} gc */\nasync function vizRep(gc) {\nawait gc.graphic_sphere(0.5, 32, 32, \"#4CAF50\");\nawait gc.graphic_text(0, -0.8, 0, 0.2, \"#4CAF50\", \"Start\");\n}","description":null,"coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"is_reusable":null,"is_abstract":null,"attributes":[],"ports":[],"creation_time":"2026-06-17T10:02:22.623Z","modification_time":"2026-06-17T10:02:22.623Z","uuid_metaobject":"a51ff3af-c210-4ddd-9fbe-787c2d7a6ad4"},{"uuid":"0d592db9-ea2b-4d9d-b259-625a45b5d7a5","name":"End","geometry":"/** @param {GraphicContext} gc */\nasync function vizRep(gc) {\nawait gc.graphic_sphere(0.5, 32, 32, \"#F44336\");\nawait gc.graphic_text(0, -0.8, 0, 0.2, \"#F44336\", \"End\");\n}","description":null,"coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"is_reusable":null,"is_abstract":null,"attributes":[],"ports":[],"creation_time":"2026-06-17T10:02:22.623Z","modification_time":"2026-06-17T10:02:22.623Z","uuid_metaobject":"0d592db9-ea2b-4d9d-b259-625a45b5d7a5"},{"uuid":"e786c4ff-10cc-4611-a712-3b1255ca35c1","name":"Process","geometry":"/** @param {GraphicContext} gc */\nasync function vizRep(gc) {\nlet name = await gc.expression.attrvalByName(\"Name\") || \"Process\";\nlet desc = await gc.expression.attrvalByName(\"Description\") || \"\";\nawait gc.graphic_cube(2, 1.2, 0.1, \"#2196F3\");\nawait gc.graphic_text(0, 0.2, 0.06, 0.25, \"white\", name);\nawait gc.graphic_text(0, -0.2, 0.06, 0.15, \"#BBD