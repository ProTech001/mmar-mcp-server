{"uuid":"6d854d5f-9ddb-474e-9b80-038e174964bb","name":"Petri Net Trial 1","geometry":null,"description":"A Petri Net modeling language with Place nodes (green spheres), Transition nodes (dark rectangular bars), and Arc connections (arrow lines). Places have Tokens/Integer and Name/String attributes, Transitions have Name/String, and Arcs have Weight/Integer.","coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"classes":[{"uuid":"f3fd1568-28a2-4daf-af8f-b00a8e91ae33","name":"Place","geometry":"/** @param {GraphicContext} gc */\nasync function vizRep(gc) {\nlet name = await gc.expression.attrvalByName(\"Name\") || \"Place\";\nlet tokens = await gc.expression.attrvalByName(\"Tokens\") || \"0\";\nawait gc.graphic_sphere(0.6, 32, 32, \"#4CAF50\");\nawait gc.graphic_text(0, 0, 0.61, 0.2, \"white\", tokens);\nawait gc.graphic_text(0, -0.9, 0, 0.2, \"black\", name);\n}","description":null,"coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"is_reusable":null,"is_abstract":null,"attributes":[{"uuid":"21fd57a5-aa6a-484b-8c42-de8f64607ae8","name":"Name","geometry":null,"description":null,"coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"multi_valued":false,"default_value":"Place","attribute_type":{"uuid":"85897325-c2b3-4ca7-8902-8120300a08dc","name":"String","geometry":"","description":"Name AttributeType","coordinates_2d":null,"relative_coordinate_3d":null,"absolute_coordinate_3d":null,"rotation":{"x":0,"y":0,"z":0,"w":1},"pre_defined":true,"regex_value":"^([\\x09\\x0A\\x0D\\x20-\\x7E]|[\\xC2-\\xDF][\\x80-\\xBF]|\\xE0[\\xA0-\\xBF][\\x80-\\xBF]|[\\xE1-\\xEC\\xEE\\xEF][\\x80-\\xBF]{2}|\\xED[\\x80-\\x9F][\\x80-\\xBF]|\\xF0[\\x90-\\xBF][\\x80-\\xBF]{2}|[\\xF1-\\xF3][\\x80-\\xBF]{3}|\\xF4[\\x80-\\x8F][\\x80-\\xBF]{2})*$","has_table_attribute":[],"creation_time":"2023-08-24T13:10: